# ============================================
# Smart Design Digital Pro - Environment Variables
# ============================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.

# --- REQUIRED ---

# OpenAI API Key for Image-to-Code analysis (GPT-4 Vision)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# Admin Dashboard Password (protects /admin routes)
ADMIN_PASSWORD=change-this-to-a-strong-password

# --- OPTIONAL (Sanity CMS) ---

# Sanity project ID (required for CMS features like Pricing & Testimonials)
# Create a project at: https://www.sanity.io/get-started/create-project
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=your-sanity-token

# --- OPTIONAL (Deployment) ---

# Public site URL (used in admin dashboard links)
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# GitHub repository URL (shown in admin dashboard)
NEXT_PUBLIC_GITHUB_URL=https://github.com/your-username/your-repo
